@import 'miniprogram/styles/theme.wxss';

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #1c1917;
  background-color: #f5f5f4;
  -webkit-font-smoothing: antialiased;
}

/* Global utility classes */
.container {
  padding: 24rpx 32rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #f0efed;
  overflow: hidden;
}

.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #44403c;
  margin-bottom: 20rpx;
}

/* Toast notification */
.notice-success {
  background: #ecfdf5;
  border: 1rpx solid #a7f3d0;
  color: #065f46;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.notice-error {
  background: #fef2f2;
  border: 1rpx solid #fecaca;
  color: #991b1b;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

/* Loading skeleton */
.skeleton {
  background: linear-gradient(90deg, #e7e5e4 25%, #d6d3d1 50%, #e7e5e4 75%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: 16rpx;
}

@keyframes skeleton-loading {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}
