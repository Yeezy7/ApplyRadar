@import '../../styles/theme.wxss';

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input-wrap {
  flex: 1;
  background: #ffffff;
  border: 1rpx solid #e7e5e4;
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.search-input {
  height: 72rpx;
  font-size: 28rpx;
}

.new-btn {
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  padding: 0 28rpx;
  white-space: nowrap;
}

.loading-wrap {
  display: flex;
  gap: 16rpx;
  overflow: hidden;
}

.skeleton-col {
  min-width: 280rpx;
  height: 600rpx;
  flex-shrink: 0;
}

/* Kanban Board */
.kanban-scroll {
  white-space: nowrap;
  margin: 0 -32rpx;
  padding: 0 32rpx;
}

.kanban-board {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 24rpx;
}

.kanban-column {
  display: inline-flex;
  flex-direction: column;
  width: 320rpx;
  background: #fafaf9;
  border-radius: 24rpx;
  min-height: 400rpx;
  flex-shrink: 0;
}

.column-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
}

.column-label {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.column-count {
  font-size: 22rpx;
  color: #a8a29e;
  font-weight: 500;
}

.column-cards {
  flex: 1;
  padding: 0 12rpx 12rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* Kanban Card */
.kanban-card {
  background: #ffffff;
  border: 1rpx solid #f0efed;
  border-radius: 16rpx;
  padding: 20rpx;
}

.kanban-card:active {
  background: #fafaf9;
}

.card-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.card-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, #e7e5e4, #d6d3d1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #57534e;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-company {
  font-size: 26rpx;
  font-weight: 600;
  color: #1c1917;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.card-location {
  font-size: 20rpx;
  color: #a8a29e;
  display: block;
}

.card-job {
  font-size: 22rpx;
  color: #57534e;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
  white-space: normal;
}

.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.tag-priority {
  background: #fef2f2;
  color: #dc2626;
}

.tag-days {
  background: #fffbeb;
  color: #d97706;
}

.tag-salary {
  background: #f5f5f4;
  color: #78716c;
}

.card-date {
  font-size: 18rpx;
  color: #a8a29e;
  flex-shrink: 0;
}

.column-empty {
  text-align: center;
  padding: 40rpx 0;
}

.column-empty-text {
  font-size: 22rpx;
  color: #d6d3d1;
}

/* Action Sheet */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.action-sheet {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
}

.action-sheet-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
  text-align: center;
  margin-bottom: 24rpx;
}

.action-sheet-item {
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  color: #1c1917;
  border-bottom: 1rpx solid #f5f5f4;
}

.action-sheet-item:active {
  background: #f5f5f4;
}

.action-sheet-cancel {
  padding: 28rpx;
  text-align: center;
  font-size: 30rpx;
  color: #a8a29e;
  margin-top: 16rpx;
}
