<view class="container page-with-tabbar">
  <!-- Loading skeleton -->
  <view wx:if="{{loading}}" class="skeleton-grid">
    <view class="skeleton skeleton-card" wx:for="{{4}}" wx:key="index"></view>
  </view>

  <block wx:else>
    <!-- Header with refresh -->
    <view class="dashboard-header">
      <view class="header-left">
        <text class="header-greeting">{{greeting}}</text>
        <text class="header-subtitle">求职进度一览</text>
      </view>
      <view class="refresh-btn" bind:tap="loadDashboard">
        <text class="refresh-icon">↻</text>
      </view>
    </view>

    <!-- Stat Cards -->
    <view class="stat-grid">
      <stat-card
        label="总投递"
        value="{{stats.total}}"
        iconText="投"
        gradient="total"
      />
      <stat-card
        label="进行中"
        value="{{stats.active}}"
        iconText="进"
        gradient="active"
      />
      <stat-card
        label="本周新增"
        value="{{stats.thisWeek}}"
        iconText="周"
        gradient="week"
      />
      <stat-card
        label="待处理"
        value="{{stats.pendingReminders}}"
        iconText="待"
        gradient="pending"
      />
    </view>

    <!-- Status Breakdown -->
    <view class="section card" wx:if="{{statusBreakdown.length > 0}}">
      <view class="section-header">
        <text class="section-title">状态分布</text>
      </view>
      <view class="status-list">
        <view class="status-item" wx:for="{{statusBreakdown}}" wx:key="status">
          <view class="status-row">
            <text class="status-label">{{item.label}}</text>
            <text class="status-count">{{item.count}}</text>
          </view>
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.percentage}}%"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- Recent Applications -->
    <view class="section card">
      <view class="section-header">
        <text class="section-title">最近更新</text>
        <text class="section-link" bind:tap="goToApplications">查看全部</text>
      </view>

      <empty-state
        wx:if="{{recentApps.length === 0}}"
        icon="投"
        title="暂无求职记录"
        description="在「投递」页面添加"
      />

      <view class="recent-list" wx:else>
        <view
          class="recent-item"
          wx:for="{{recentApps}}"
          wx:key="_id"
          bind:tap="goToDetail"
          data-id="{{item._id}}"
        >
          <view class="recent-avatar">{{item.initial}}</view>
          <view class="recent-info">
            <text class="recent-company">{{item.company_name}}</text>
            <text class="recent-job">{{item.job_title}}</text>
          </view>
          <view class="recent-right">
            <view class="badge status-{{item.status}}">{{item.statusLabel}}</view>
            <text class="recent-date">{{item.dateStr}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Alerts -->
    <view class="alerts" wx:if="{{stats.offers > 0 || stats.loginExpired > 0}}">
      <view class="alert alert-success" wx:if="{{stats.offers > 0}}">
        <text class="alert-text">{{stats.offers}} 个 Offer - 恭喜！</text>
      </view>
      <view class="alert alert-warning" wx:if="{{stats.loginExpired > 0}}">
        <text class="alert-text">{{stats.loginExpired}} 个登录过期 - 需要重新登录</text>
      </view>
    </view>
  </block>
</view>
<custom-tabbar id="tabbar" />
