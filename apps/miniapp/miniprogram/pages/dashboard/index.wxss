@import '../../styles/theme.wxss';

.skeleton-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.skeleton-card {
  height: 200rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-subtitle {
  font-size: 22rpx;
  color: #a8a29e;
}

/* Status Breakdown */
.status-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.status-item {
  display: flex;
  flex-direction: column;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.status-label {
  font-size: 26rpx;
  color: #57534e;
}

.status-count {
  font-size: 26rpx;
  font-weight: 600;
  color: #1c1917;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: #f5f5f4;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #57534e;
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

/* Recent Applications */
.recent-list {
  display: flex;
  flex-direction: column;
}

.recent-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f4;
}

.recent-item:last-child {
  border-bottom: none;
}

.recent-item:active {
  background: #fafaf9;
}

.recent-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #e7e5e4, #d6d3d1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #57534e;
  flex-shrink: 0;
}

.recent-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.recent-company {
  font-size: 28rpx;
  font-weight: 500;
  color: #1c1917;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recent-job {
  font-size: 22rpx;
  color: #78716c;
  margin-top: 4rpx;
}

.recent-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.recent-date {
  font-size: 22rpx;
  color: #a8a29e;
}

/* Alerts */
.alerts {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.alert {
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
}

.alert-success {
  background: #ecfdf5;
  border: 1rpx solid #a7f3d0;
}

.alert-warning {
  background: #fffbeb;
  border: 1rpx solid #fde68a;
}

.alert-text {
  font-size: 26rpx;
  color: #1c1917;
}
