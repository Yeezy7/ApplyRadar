<view class="container page-with-tabbar">
  <!-- Search & Filter Bar -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <input
        class="search-input"
        placeholder="搜索公司或岗位..."
        value="{{search}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
    </view>
    <picker
      mode="selector"
      range="{{statusOptions}}"
      range-key="label"
      value="{{statusPickerIndex}}"
      bindchange="onStatusFilter"
    >
      <view class="filter-btn">
        <text>{{statusPickerIndex > 0 ? statusOptions[statusPickerIndex].label : '全部状态'}}</text>
        <text class="filter-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- New Application Button -->
  <view class="action-bar">
    <button class="btn-primary new-btn" bind:tap="goToCreate">
      + 新建记录
    </button>
  </view>

  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="skeleton skeleton-item" wx:for="{{5}}" wx:key="index"></view>
  </view>

  <!-- Empty State -->
  <empty-state
    wx:elif="{{applications.length === 0}}"
    icon="投"
    title="暂无求职记录"
    description="点击「新建记录」开始添加"
  />

  <!-- Application List -->
  <view wx:else class="app-list">
    <app-card
      wx:for="{{applications}}"
      wx:key="_id"
      application="{{item}}"
      bind:tap="goToDetail"
    />
  </view>
</view>
<custom-tabbar id="tabbar" />
