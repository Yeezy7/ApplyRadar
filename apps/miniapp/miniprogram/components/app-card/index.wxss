.app-card {
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #f0efed;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.app-card:active {
  background: #fafaf9;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.card-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #e7e5e4, #d6d3d1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #57534e;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-company {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1917;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-job {
  font-size: 24rpx;
  color: #78716c;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-location {
  font-size: 22rpx;
  color: #a8a29e;
  margin-top: 2rpx;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  flex-shrink: 0;
}

.priority-tag {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-weight: 500;
}

.priority-high {
  background: #fef2f2;
  color: #dc2626;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f4;
}

.card-salary {
  font-size: 24rpx;
  color: #78716c;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-days {
  font-size: 24rpx;
  color: #a8a29e;
}

.days-warning {
  color: #d97706;
  font-weight: 500;
}

.card-source {
  font-size: 20rpx;
  color: #a8a29e;
  padding: 2rpx 10rpx;
  background: #f5f5f4;
  border-radius: 4rpx;
}
