.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #78716c;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #a8a29e;
}
